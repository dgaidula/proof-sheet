    "node": ">=20"
  },
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "contact-sheet",
    "proof-sheet",
    "image-review",
    "batch",
    "html",
    "diff",
    "qa",
    "cli"
  ],
